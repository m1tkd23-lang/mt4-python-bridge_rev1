{
  "_meta": {
    "relative_path": "src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/schemas/plan_director_report.schema.json"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanDirectorReport",
  "type": "object",
  "required": [
    "source_task_id",
    "role",
    "cycle",
    "decision",
    "selected_proposal_id",
    "selected_planner_role",
    "selection_reason",
    "scores"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "relative_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "relative_path"
      ],
      "additionalProperties": true
    },
    "source_task_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "const": "plan_director"
    },
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "adopt",
        "no_adopt"
      ]
    },
    "selected_proposal_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^proposal_[0-9]{4}$"
    },
    "selected_planner_role": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "planner_safe",
        "planner_improvement",
        null
      ]
    },
    "selection_reason": {
      "type": "string",
      "minLength": 1
    },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "planner_role",
          "proposal_id",
          "proposal_state",
          "score",
          "reason"
        ],
        "properties": {
          "planner_role": {
            "type": "string",
            "enum": [
              "planner_safe",
              "planner_improvement"
            ]
          },
          "proposal_id": {
            "type": "string",
            "pattern": "^proposal_[0-9]{4}$"
          },
          "proposal_state": {
            "type": "string",
            "enum": [
              "proposed",
              "accepted",
              "rejected",
              "deferred",
              "task_created"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "adopt"
          }
        }
      },
      "then": {
        "properties": {
          "selected_proposal_id": {
            "type": "string",
            "pattern": "^proposal_[0-9]{4}$"
          },
          "selected_planner_role": {
            "type": "string",
            "enum": [
              "planner_safe",
              "planner_improvement"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "no_adopt"
          }
        }
      },
      "then": {
        "properties": {
          "selected_proposal_id": {
            "type": "null"
          },
          "selected_planner_role": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": true
}