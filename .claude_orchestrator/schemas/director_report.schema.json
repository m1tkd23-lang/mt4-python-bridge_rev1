{
  "_meta": {
    "relative_path": "src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/schemas/director_report.schema.json"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DirectorReport",
  "type": "object",
  "required": [
    "task_id",
    "role",
    "cycle",
    "final_action",
    "used_skills",
    "summary",
    "next_actions",
    "remaining_risks",
    "docs_decision"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "relative_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["relative_path"],
      "additionalProperties": true
    },

    "task_id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "const": "director" },
    "cycle": { "type": "integer", "minimum": 1 },

    "final_action": {
      "type": "string",
      "enum": ["approve", "revise", "stop"]
    },

    "used_skills": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "summary": {
      "type": "string",
      "minLength": 1
    },

    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "remaining_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "docs_decision": {
      "type": "object",
      "required": ["status", "reason", "followup_actions"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["sufficient", "followup_needed", "not_applicable"]
        },
        "reason": { "type": "string", "minLength": 1 },
        "followup_actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },

    "approval_basis": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "carry_over_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "completion_assessment": {
      "type": "string",
      "enum": ["complete", "partial", "insufficient"]
    }
  },
  "additionalProperties": true
}