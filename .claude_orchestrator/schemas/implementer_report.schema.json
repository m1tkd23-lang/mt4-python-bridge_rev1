{
  "_meta": {
    "relative_path": "src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/schemas/implementer_report.schema.json"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ImplementerReport",
  "type": "object",
  "required": [
    "task_id",
    "role",
    "cycle",
    "status",
    "used_skills",
    "summary",
    "changed_files",
    "commands_run",
    "results",
    "risks",
    "questions",
    "docs_update_result"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "relative_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["relative_path"],
      "additionalProperties": true
    },

    "task_id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "const": "implementer" },
    "cycle": { "type": "integer", "minimum": 1 },

    "status": {
      "type": "string",
      "enum": ["done", "blocked", "need_input"]
    },

    "used_skills": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "summary": {
      "type": "string",
      "minLength": 1
    },

    "changed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "commands_run": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "results": {
      "type": "array",
      "items": { "type": "object" }
    },

    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "docs_update_result": {
      "type": "object",
      "required": [
        "update_performed",
        "updated_docs",
        "update_summary",
        "pending_followup_docs"
      ],
      "properties": {
        "update_performed": { "type": "boolean" },
        "updated_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "update_summary": { "type": "string" },
        "pending_followup_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },

    "completion_level": {
      "type": "string",
      "enum": ["full", "partial", "minimal"]
    },

    "unresolved_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "next_task_hints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}