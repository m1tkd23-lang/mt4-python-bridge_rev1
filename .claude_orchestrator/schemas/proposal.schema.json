{
  "_meta": {
    "relative_path": "src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/schemas/proposal.schema.json"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proposal",
  "type": "object",
  "required": [
    "_meta",
    "proposal_id",
    "planner_type",
    "source_task_id",
    "source_cycle",
    "title",
    "description",
    "why_now",
    "priority",
    "proposal_kind",
    "reason",
    "context_files",
    "constraints",
    "depends_on",
    "docs_update_plan",
    "state",
    "created_task_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "required": [
        "relative_path"
      ],
      "properties": {
        "relative_path": {
          "type": "string",
          "pattern": "^\\.claude_orchestrator/tasks/TASK-[0-9]{4}/planner/proposals/(planner_safe|planner_improvement)/cycle_[0-9]+/proposal_[0-9]{4}\\.json$"
        }
      },
      "additionalProperties": true
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^proposal_[0-9]{4}$"
    },
    "planner_type": {
      "type": "string",
      "enum": [
        "safe",
        "improvement"
      ]
    },
    "source_task_id": {
      "type": "string",
      "minLength": 1
    },
    "source_cycle": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "why_now": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "proposal_kind": {
      "type": "string",
      "enum": [
        "safe",
        "improvement",
        "challenge"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "context_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "docs_update_plan": {
      "type": "object",
      "required": [
        "update_needed",
        "target_docs",
        "update_purpose",
        "update_timing",
        "notes"
      ],
      "properties": {
        "update_needed": {
          "type": "boolean"
        },
        "target_docs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "update_purpose": {
          "type": "string"
        },
        "update_timing": {
          "type": "string",
          "enum": [
            "same_task",
            "followup_task",
            "no_update"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "update_needed": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "target_docs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "update_timing": {
                "type": "string",
                "enum": [
                  "same_task",
                  "followup_task"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "update_needed": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "target_docs": {
                "type": "array",
                "maxItems": 0
              },
              "update_timing": {
                "const": "no_update"
              }
            }
          }
        }
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "deferred",
        "task_created"
      ]
    },
    "created_task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}