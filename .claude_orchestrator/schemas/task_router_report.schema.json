{
  "_meta": {
    "relative_path": "src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/schemas/task_router_report.schema.json"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskRouterReport",
  "type": "object",
  "required": [
    "task_id",
    "role",
    "cycle",
    "status",
    "task_type",
    "risk_level",
    "role_skill_plan",
    "used_skills",
    "skill_selection_reason",
    "initial_execution_notes",
    "docs_update_plan"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "relative_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "relative_path"
      ],
      "additionalProperties": true
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "const": "task_router"
    },
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "task_type": {
      "type": "string",
      "enum": [
        "feature",
        "bugfix",
        "refactor",
        "docs",
        "research",
        "chore"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "role_skill_plan": {
      "type": "object",
      "required": [
        "implementer",
        "reviewer",
        "director"
      ],
      "properties": {
        "implementer": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewer": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "director": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "used_skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skill_selection_reason": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "initial_execution_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "docs_update_plan": {
      "type": "object",
      "required": [
        "needs_update",
        "target_docs",
        "update_reason",
        "update_instructions"
      ],
      "properties": {
        "needs_update": {
          "type": "boolean"
        },
        "target_docs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "update_reason": {
          "type": "string"
        },
        "update_instructions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}