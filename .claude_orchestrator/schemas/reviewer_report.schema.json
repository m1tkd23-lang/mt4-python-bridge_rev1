{
  "_meta": {
    "relative_path": "src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/schemas/reviewer_report.schema.json"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewerReport",
  "type": "object",
  "required": [
    "task_id",
    "role",
    "cycle",
    "decision",
    "used_skills",
    "summary",
    "must_fix",
    "nice_to_have",
    "risks",
    "docs_review_result"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "relative_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["relative_path"],
      "additionalProperties": true
    },

    "task_id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "const": "reviewer" },
    "cycle": { "type": "integer", "minimum": 1 },

    "decision": {
      "type": "string",
      "enum": ["ok", "needs_fix", "blocked"]
    },

    "used_skills": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "summary": {
      "type": "string",
      "minLength": 1
    },

    "must_fix": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "nice_to_have": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "docs_review_result": {
      "type": "object",
      "required": ["checked", "consistency_ok", "issues", "notes"],
      "properties": {
        "checked": { "type": "boolean" },
        "consistency_ok": { "type": "boolean" },
        "issues": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },

    "decision_basis": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "blocking_points": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "followup_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}